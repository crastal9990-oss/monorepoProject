{
  "extends": "../../packages/typescript-config/base.json",
  "compilerOptions": {
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      // 所有 @/ 开头的普通模块依然会在 web-app 的当前目录下寻找。
      "@/*": [
        "./*"  
      ],
      // 唯独遇到 @/lib/utils 时，Next.js 会精准地去 ../../packages/ui/src/lib/utils 获取。
      "@/lib/utils": [
        "../../packages/ui/src/lib/utils"
      ],
      "@ui/*": [
        "../../packages/ui/src/*"
      ]
    },
    "allowJs": true,
    "noEmit": true,
    "incremental": true,
    "module": "esnext",
    "resolveJsonModule": true,
    "jsx": "preserve"
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}